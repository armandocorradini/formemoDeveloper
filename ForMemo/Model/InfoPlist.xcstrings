    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This app uses the camera to scan documents and attach photos to your tasks." }},
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Questa app usa la fotocamera per scansionare documenti e allegare foto alle tue attività." }},
