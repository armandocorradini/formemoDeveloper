    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App greift auf Ihren Kalender zu, um Ereignisse als Aufgaben zu importieren und zu verwalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app accesses your calendar to import and manage events as tasks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta aplicación accede a tu calendario para importar y gestionar eventos como tareas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette application accède à votre calendrier pour importer et gérer des événements comme des tâches."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa app accede al tuo calendario per importare e gestire eventi come attività."
          }
        }
      }
    },
