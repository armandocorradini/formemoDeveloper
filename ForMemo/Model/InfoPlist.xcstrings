    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This app accesses your calendar to import and manage events as tasks." }},
