      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App ermöglicht es Ihnen, Fotos aus Ihrer Mediathek an Ihre Aufgaben anzuhängen."
