    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App nutzt die Kamera, um Dokumente zu scannen und Fotos an Ihre Aufgaben anzuhängen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app uses the camera to scan documents and attach photos to your tasks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta aplicación utiliza la cámara para escanear documentos y adjuntar fotos a tus tareas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette application utilise l’appareil photo pour scanner des documents et joindre des photos à vos tâches."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa app usa la fotocamera per scansionare documenti e allegare foto alle tue attività."
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo verwendet Ihren Standort im Hintergrund, um Sie zu benachrichtigen, wenn Sie an einem gespeicherten Aufgabenort ankommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo uses your location in the background to notify you when you arrive at a saved task location."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utiliza tu ubicación en segundo plano para avisarte cuando llegues a una ubicación asociada a una tarea guardada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utilise votre position en arrière-plan pour vous notifier lorsque vous arrivez à un lieu associé à une tâche enregistrée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo usa la tua posizione in background per notificarti quando arrivi in un luogo associato a un’attività salvata."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo verwendet Ihren Standort, damit Sie Orte an Ihre Aufgaben anhängen können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo uses your location to let you attach places to your tasks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utiliza tu ubicación para permitirte asociar lugares a tus tareas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utilise votre position pour vous permettre d’associer des lieux à vos tâches."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo usa la tua posizione per consentirti di associare luoghi alle tue attività."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo verwendet das Mikrofon, um Sprachnotizen für Ihre Aufgaben aufzunehmen."
