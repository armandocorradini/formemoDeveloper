        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utiliza el micrófono para grabar notas de voz para tus tareas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ForMemo utilise le microphone pour enregistrer des notes vocales pour vos tâches."
