    "What do you want to add?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was möchtest du hinzufügen?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Qué quieres añadir?"
          }
        },
        "fr" : {
          "stringUnit" : {
