    "%@ automatically uses your Apple ID and your personal iCloud account. No sign in or additional account is required." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ verwendet automatisch deine Apple-ID und deinen persönlichen iCloud-Account. Es ist keine Anmeldung oder ein zusätzliches Konto erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ utiliza automáticamente tu ID de Apple y tu cuenta personal de iCloud. No es necesario iniciar sesión ni crear una cuenta adicional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ utilise automatiquement votre identifiant Apple et votre compte iCloud personnel. Aucune connexion ni compte supplémentaire n’est requis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ utilizza automaticamente il tuo ID Apple e il tuo account iCloud personale. Non è richiesto alcun accesso o account aggiuntivo."
          }
        }
      }
    },
