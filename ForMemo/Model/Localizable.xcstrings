    "Stay on track with intelligent reminders. Notifications adapt to your schedule and let you quickly snooze or open tasks." : {
      "comment" : "Notification type: information.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie organisiert mit intelligenten Erinnerungen. Benachrichtigungen passen sich Ihrem Zeitplan an und ermöglichen es Ihnen, Aufgaben schnell zu verschieben oder zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantente al día con recordatorios inteligentes. Las notificaciones se adaptan a tu agenda y te permiten posponer o abrir tareas rápidamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez organisé grâce à des rappels intelligents. Les notifications s’adaptent à votre emploi du temps et vous permettent de reporter ou d’ouvrir rapidement vos tâches."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimani organizzato con promemoria intelligenti. Le notifiche si adattano ai tuoi impegni e ti permettono di posticipare o aprire rapidamente le attività."
          }
        }
      }
    },
