    "This action will permanently remove all attachments of completed tasks. This cannot be undone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Aktion entfernt dauerhaft alle Anhänge abgeschlossener Aufgaben. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta acción eliminará de forma permanente todos los archivos adjuntos de las tareas completadas. Esta acción non se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprimera définitivement toutes les pièces jointes des tâches terminées. Cette opération est irréversible."
