    "This feature applies only to tasks created with Siri. The app analyzes the task title using a multilingual keyword system. Each category has its own keywords, and the best match is applied automatically." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Funktion gilt nur für mit Siri erstellte Aufgaben. Die App analysiert den Titel mit einem mehrsprachigen Schlüsselwortsystem und weist automatisch die beste Kategorie zu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta función se aplica solo a tareas creadas con Siri. La app analiza el título usando un sistema multilingüe de palabras clave y aplica automáticamente la mejor coincidencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette fonctionnalité s’applique uniquement aux tâches créées avec Siri. L’app analyse le titre à l’aide d’un système de mots-clés multilingue et applique automatiquement la meilleure correspondance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa funzionalità si applica solo alle attività create con Siri. L’app analizza il titolo usando un sistema di parole chiave multilingua e applica automaticamente la corrispondenza migliore."
          }
        }
      }
    },
