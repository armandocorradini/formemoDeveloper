    "Location accuracy, permissions, or system limits may affect this. Make sure location access is set to Always and that the task is actively monitored." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standortgenauigkeit, Berechtigungen oder Systemgrenzen können dies beeinflussen. Stellen Sie sicher, dass der Standortzugriff auf „Immer“ gesetzt ist und die Aufgabe aktiv überwacht wird."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La precisión de la ubicación, los permisos o los límites del sistema pueden influir. Asegúrate de que el acceso a la ubicación esté configurado en “Siempre” y que la tarea esté siendo monitorizada activamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La précision de la localisation, les autorisations ou les limites du système peuvent influencer ce comportement. Assurez-vous que l’accès à la localisation est défini sur “Toujours” et que la tâche est activement surveillée."
          }
        },
        "it" : {
          "stringUnit" : {
