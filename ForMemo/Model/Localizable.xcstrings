      }
    },
    "Siri will ask for the activity title and due date, then create the record. Choose whether to set a reminder automatically or have Siri ask you." : {
      "comment" : "A description of the Siri feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri fragt nach dem Titel der Aktivität und dem Fälligkeitsdatum und erstellt dann den Eintrag. Wähle, ob eine Erinnerung automatisch gesetzt werden soll oder ob Siri dich danach fragen soll."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri te pedirá el título de la actividad y la fecha de vencimiento, y luego creará el elemento. Elige si deseas establecer un recordatorio automáticamente o que Siri te lo pregunte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri vous demandera le titre de l’activité et la date d’échéance, puis créera l’élément. Choisissez de définir un rappel automatiquement ou de laisser Siri vous le demander."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri chiederà il titolo dell’attività e la data di scadenza, quindi creerà l’elemento. Scegli se impostare un promemoria automaticamente oppure lasciare che Siri te lo chieda."
          }
        }
      }
    },
