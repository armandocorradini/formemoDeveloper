          }
        }
      }
    },
    "Notification times depend on the task date, reminder settings, and system adjustments. The app avoids past or invalid times and schedules only valid future alerts." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Zeiten der Benachrichtigungen hängen vom Aufgabendatum, den Erinnerungseinstellungen und Systemanpassungen ab. Die App vermeidet vergangene oder ungültige Zeiten und plant nur gültige zukünftige Hinweise."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los horarios de las notificaciones dependen de la fecha de la tarea, de los ajustes de recordatorio y de ajustes del sistema. La app evita horarios pasados o no válidos y programa solo avisos futuros válidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les horaires des notifications dépendent de la date de la tâche, des réglages de rappel et des ajustements du système. L’app évite les horaires passés ou invalides et ne planifie que des alertes futures valides."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli orari delle notifiche dipendono dalla data dell’attività, dalle impostazioni dei promemoria e da eventuali correzioni del sistema. L’app evita orari passati o non validi e pianifica solo notifiche future valide."
          }
        }
      }
    },
    "Notifications" : {
