    "Siri will ask for the activity title and due date, then create the record with an automatic reminder." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri wird nach dem Titel und dem Fälligkeitsdatum fragen und anschließend automatisch eine Erinnerung erstellen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri te pedirá el título de la tarea y la fecha de vencimiento, y creará automáticamente un recordatorio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri vous demandera le titre de la tâche et la date d’échéance, puis créera automatiquement un rappel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri ti chiederà il titolo dell’attività e la data di scadenza, quindi creerà automaticamente un promemoria."
          }
        }
      }
    },
