    "Notifications are updated dynamically. If a task changes, old notifications are removed and replaced with new ones, which can make them appear different." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen werden dynamisch aktualisiert. Wenn sich eine Aufgabe ändert, werden alte Hinweise entfernt und durch neue ersetzt, was sie unterschiedlich erscheinen lassen kann."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones se actualizan dinámicamente. Si una tarea cambia, las anteriores se eliminan y se sustituyen por nuevas, lo que puede hacer que parezcan diferentes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notifications sont mises à jour dynamiquement. Si une tâche change, les anciennes notifications sont supprimées et remplacées par de nouvelles, ce qui peut les faire paraître différentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le notifiche vengono aggiornate dinamicamente. Se un’attività cambia, quelle vecchie vengono rimosse e sostituite con nuove, quindi possono sembrare diverse."
          }
        }
      }
    },
    "Notifications must be enabled in system settings to receive alerts and sounds." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitteilungen müssen in den Systemeinstellungen aktiviert sein, um Hinweise und Töne zu erhalten."
