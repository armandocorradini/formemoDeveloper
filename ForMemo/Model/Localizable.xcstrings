    "Your tasks and attachments are stored only in your personal iCloud account. The developer does not run any server and cannot access your data." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Aufgaben und Anhänge werden ausschließlich in deinem persönlichen iCloud-Konto gespeichert. Der Entwickler betreibt keine Server und hat keinen Zugriff auf deine Daten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus tareas y adjuntos se almacenan exclusivamente en tu cuenta personal de iCloud. El desarrollador no gestiona ningún servidor y no tiene acceso a tus datos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos tâches et pièces jointes sont stockées uniquement sur votre compte iCloud personnel. Le développeur n'exploite aucun serveur et ne peut pas accéder à vos données."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le tue attività e gli allegati sono memorizzati esclusivamente sul tuo account iCloud personale. Lo sviluppatore non gestisce alcun server e non può accedere ai tuoi dati."
          }
        }
      }
    }
  },
  "version" : "1.1"
