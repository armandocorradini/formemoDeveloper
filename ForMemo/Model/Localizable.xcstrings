        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para mostrar el globo en el icono de la app y recibir recordatorios y notificaciones sonoras, debes permitir las notificaciones para %@."
          }
        },
        "fr" : {
          "stringUnit" : {
