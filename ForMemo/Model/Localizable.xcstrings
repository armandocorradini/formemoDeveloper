    "Stay on track with timely reminders. Long-press a notification to quickly snooze a task or open the app." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie mit rechtzeitigen Erinnerungen auf Kurs. Halten Sie eine Benachrichtigung gedrückt, um eine Aufgabe schnell zu verschieben oder die App zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie mit rechtzeitigen Erinnerungen auf Kurs. Halten Sie eine Benachrichtigung gedrückt, um eine Aufgabe schnell zu verschieben oder die App zu öffnen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez sur la bonne voie grâce à des rappels ponctuels. Maintenez une notification enfoncée pour reporter rapidement une tâche ou ouvrir l’app."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai al passo con promemoria puntuali. Tieni premuta una notifica per posticipare rapidamente un’attività oppure aprire l’app."
          }
        }
      }
