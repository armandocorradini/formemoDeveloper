    "Siri replies briefly after creating a task." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siri antwortet kurz nach dem Erstellen einer Aufgabe."
          }
        },
        "es" : {
          "stringUnit" : {
