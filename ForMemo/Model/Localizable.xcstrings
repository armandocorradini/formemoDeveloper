    "Specific Day" : {
      "comment" : "Display representation of a task period case for a custom date.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bestimmter Tag"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Día Específico"
          }
        },
