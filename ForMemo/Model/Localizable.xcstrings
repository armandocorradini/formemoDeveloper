    "Tasks change color automatically based on their category. Overdue tasks and upcoming deadlines are visually highlighted." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgaben ändern automatisch ihre Farbe je nach Typ. Überfällige Aufgaben und bevorstehende Fristen werden visuell hervorgehoben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las tareas cambian de color automáticamente según su tipo. Las tareas vencidas y las fechas próximas se resaltan visualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les tâches changent de couleur automatiquement selon leur type. Les échéances dépassées et les dates limites proches restent mises en évidence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le attività cambiano colore automaticamente in base alla loro tipologia. Le scadenze passate e quelle imminenti rimangono evidenziate visivamente."
          }
        }
      }
    },
