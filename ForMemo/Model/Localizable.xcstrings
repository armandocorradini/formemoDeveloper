        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa azione rimuoverà permanentemente tutti gli allegati delle attività completate. L'operazione non può essere annullata."
          }
        }
      }
    },
    "This will permanently delete all your tasks and attachments. This cannot be undone. Changes will sync automatically with iCloud." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies wird all Ihre Aufgaben und Anhänge dauerhaft löschen. Dies kann nicht rückgängig gemacht werden. Änderungen werden automatisch mit iCloud synchronisiert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará de forma permanente todas tus tareas y adjuntos. No se puede deshacer. Los cambios se sincronizarán automáticamente con iCloud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement toutes vos tâches et pièces jointes. Cette opération est irréversible. Les modifications seront synchronisées automatiquement avec iCloud."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo eliminerà permanentemente tutte le tue attività e gli allegati. L'azione non può essere annullata. Le modifiche verranno sincronizzate automaticamente con iCloud."
          }
        }
      }
    },
    "This will permanently remove all tasks and attachments." : {
