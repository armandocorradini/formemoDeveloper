    "Import tasks from Apple Reminders, Calendar or CSV files. Avoid duplicates and keep everything in one place.\n\nNote: attachments are not included in imports." : {
      "comment" : "Text describing how to import tasks from Apple Reminders, Calendar or CSV files, including instructions on avoiding duplicates and how to keep everything in one place. Note: attachments are not included in imports.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importieren Sie Aufgaben aus Apple Erinnerungen, Kalender oder CSV-Dateien. Vermeiden Sie Duplikate und behalten Sie alles an einem Ort.\n\nHinweis: Anhänge werden beim Import nicht berücksichtigt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importa tareas desde Recordatorios de Apple, Calendario o archivos CSV. Evita duplicados y mantén todo en un solo lugar.\n\nNota: los archivos adjuntos no se incluyen en las importaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importez des tâches depuis Apple Rappels, Calendrier ou des fichiers CSV. Évitez les doublons et gardez tout au même endroit.\n\nRemarque : les pièces jointes ne sont pas incluses dans les importations."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importa attività da Apple Promemoria, Calendario o file CSV. Evita duplicati e tieni tutto in un unico posto.\n\nNota: gli allegati non sono inclusi nelle importazioni."
          }
        }
      }
    },
