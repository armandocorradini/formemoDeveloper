      }
    },
    "Make sure notifications are enabled in iOS Settings, Focus modes are not blocking alerts, and the task has a valid date or reminder. The app only schedules notifications when they are meaningful." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stellen Sie sicher, dass Benachrichtigungen in den iOS-Einstellungen aktiviert sind, Fokusmodi keine Hinweise blockieren und die Aufgabe ein gültiges Datum oder eine Erinnerung hat. Die App plant nur sinnvolle Benachrichtigungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asegúrate de que las notificaciones estén activadas en los ajustes de iOS, que los modos de concentración no bloqueen los avisos y que la tarea tenga una fecha o recordatorio válido. La app solo programa notificaciones cuando son útiles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assurez-vous que les notifications sont activées dans les réglages iOS, que les modes Concentration ne bloquent pas les alertes et que la tâche possède une date ou un rappel valide. L’app ne planifie des notifications que lorsqu’elles sont pertinentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assicurati che le notifiche siano attive nelle impostazioni iOS, che le modalità Focus non blocchino gli avvisi e che l’attività abbia una data o un promemoria valido. L’app pianifica notifiche solo quando sono utili."
          }
        }
      }
    },
